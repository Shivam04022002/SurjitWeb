# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Environment / secrets ───────────────────────────────────────────────────
# Ignore every .env variant at any depth, but keep the example templates.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# ─── Build output ────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
**/dist/
**/build/

# ─── Uploaded files (customer documents — Aadhaar, bank statements — NEVER commit) ─
# Match a folder named "uploads" anywhere, whether or not it currently exists.
uploads
uploads/
**/uploads
**/uploads/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Runtime / coverage ──────────────────────────────────────────────────────
.cache/
coverage/
*.pid
*.seed

# ─── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.suo
